# Copy this file to .env and fill in your values.
# Expo automatically loads .env — no extra config needed.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Anthropic Claude (AI Coach) ───────────────────────────────────────────────
# The API key is NOT stored here — it lives as a Supabase secret on the server.
# Run this once after deploying the edge function:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-api03-...
# The app calls the edge function; the key never touches the client bundle.
